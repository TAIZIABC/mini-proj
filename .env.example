# DeepSeek API Key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API Base (兼容 OpenAI 协议)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek 模型名
# 推荐使用 deepseek-chat（非 thinking 模式，可直接走 tool-call 多轮）
# ⚠️ 不建议用 thinking 模式的模型（如 deepseek-v4-flash / deepseek-reasoner），
#    它们要求把 reasoning_content 回传，LangChain.js 目前不会自动处理
DEEPSEEK_MODEL=deepseek-chat

# 服务端口
PORT=3000

# 小程序预览码接口（已带项目路径参数）
PREVIEW_API=http://127.0.0.1:30747/v2/preview?project=%2FUsers%2Fkingjungle%2FDocuments%2Fwork%2FAppletNew
